# Mode initial : User EXEC
# Passage en mode Privileged EXEC via enable (droit de lecture)
# Passage en mode Global COnfiguration via conf t (droit de modifier)

en
conf t

interface vlan20
    ip address 192.168.20.1 255.255.255.0
    no shutdown
exit
interface vlan21
    ip address 192.168.21.1 255.255.255.0
    no shutdown
exit
interface vlan22
    ip address 192.168.22.1 255.255.255.0
    no shutdown
exit

end
write memory
