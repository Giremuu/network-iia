# Mode initial : User EXEC
# Passage en mode Privileged EXEC via enable (droit de lecture)
# Passage en mode Global COnfiguration via conf t (droit de modifier)

en
conf t

interface GigabitEthernet0/0/0
    no switchport
    ip address 192.168.23.2 255.255.255.252
    no shutdown
exit
end
write memory
sh run
