# Mode initial : User EXEC
# Passage en mode Privileged EXEC via enable (droit de lecture)
# Passage en mode Global COnfiguration via conf t (droit de modifier)
# ip route Réseau_Visé Mask_visé Gateway

en
conf t

interface GigabitEthernet0/0/1
    ip address 200.10.0.1 255.255.255.0
    no shutdown
exit
end
write memory
sh run